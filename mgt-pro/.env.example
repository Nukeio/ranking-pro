# Copy this file to .env.local for local dev. On Vercel, add these in
# Project Settings -> Environment Variables instead.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Project Settings -> API -> anon (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Project Settings -> API -> service_role key  ← KEEP SECRET, never NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Ingest secret ─────────────────────────────────────────────────────────────
# A long random string YOU generate (e.g. openssl rand -hex 32).
# The GitHub Action sends this as a Bearer token so /api/ingest rejects
# unauthorised callers. Add the same value on Vercel AND as a GitHub secret.
INGEST_SECRET=change-me-to-something-long-and-random

# ── GitHub Action only (NOT needed on Vercel) ─────────────────────────────────
# The accessKey captured from Proxyman (header AND body field in the MT3 request)
GAME_API_ACCESS_KEY=paste-your-captured-accesskey-here
# The game version string seen in the User-Agent / body
GAME_API_VERSION=13.063.007
# Your deployed Vercel URL, e.g. https://mt3-pro.vercel.app
SITE_URL=https://your-deployment.vercel.app
